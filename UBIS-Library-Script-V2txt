function onLibrary_UBIS(){if(state.ubis===undefined)state.ubis={};var U=state.ubis;
if(U.balance===undefined)U.balance=UBIS_CONFIG.startingBalance;
if(U.inventory===undefined)U.inventory=JSON.parse(JSON.stringify(ubisGetDefaultInventory()));
if(U.ledger===undefined)U.ledger=[];if(U.billCounters===undefined)U.billCounters={};
if(U.incomeCounters===undefined)U.incomeCounters={};if(U.turnCount===undefined)U.turnCount=0;
if(U.denied===undefined)U.denied=[];if(U.pendingCmd===undefined)U.pendingCmd="";
if(U.currentWeather===undefined)U.currentWeather="";if(U.weatherDay===undefined)U.weatherDay=-1;
if(U.time===undefined)U.time={year:UBIS_CONFIG.startYear,month:UBIS_CONFIG.startMonth,day:UBIS_CONFIG.startDay,hour:UBIS_CONFIG.startHour,totalHours:UBIS_CONFIG.startHour};
if(U.settings===undefined){U.settings={preset:UBIS_CONFIG.preset,scriptEnabled:UBIS_CONFIG.scriptEnabled,hoursPerTurn:UBIS_CONFIG.hoursPerTurn,inventoryEnabled:UBIS_CONFIG.inventoryEnabled,currencyEnabled:UBIS_CONFIG.currencyEnabled,timeEnabled:UBIS_CONFIG.timeEnabled,billsEnabled:UBIS_CONFIG.billsEnabled,currencyContextEnabled:UBIS_CONFIG.currencyContextEnabled,narratorMode:false,tiers:UBIS_CONFIG.preset==="fantasy"?UBIS_TIERS.map(function(t){return Object.assign({},t);}):null,bills:JSON.parse(JSON.stringify(ubisGetDefaultBills())),income:JSON.parse(JSON.stringify(ubisGetDefaultIncome())),priceList:JSON.parse(JSON.stringify(UBIS_CONFIG.priceList)),jobPayouts:JSON.parse(JSON.stringify(UBIS_CONFIG.jobPayouts)),holidays:JSON.parse(JSON.stringify(UBIS_CONFIG.holidays)),events:JSON.parse(JSON.stringify(UBIS_CONFIG.events)),seasons:ubisGetDefaultSeasons()};}
if(!U.settings.preset)U.settings.preset=UBIS_CONFIG.preset;
if(U.settings.narratorMode===undefined)U.settings.narratorMode=false;
if(U.currentWeather===undefined)U.currentWeather="";if(U.weatherDay===undefined)U.weatherDay=-1;
if(ubisResolvePreset()==="fantasy"&&(!U.settings.tiers||!U.settings.tiers.length))U.settings.tiers=UBIS_TIERS.map(function(t){return Object.assign({},t);});
if(!U.settings.priceList)U.settings.priceList=JSON.parse(JSON.stringify(UBIS_CONFIG.priceList));
