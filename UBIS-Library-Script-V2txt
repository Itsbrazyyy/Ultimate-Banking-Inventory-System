function ubisProcessBills(U){var notices=[];var cd=ubisTotalDays(U.time);var i,j,bill,src,ld,per,charge,pay,item,key;for(i=0;i<U.settings.bills.length;i++){bill=U.settings.bills[i];if(!bill.enabled)continue;ld=U.billCounters[bill.name]||0;per=Math.floor((cd-ld)/(bill.intervalDays||1));if(per<=0)continue;U.billCounters[bill.name]=ld+(per*bill.intervalDays);var notice="[BILL] "+bill.name+(per>1?" x"+per:"");if(bill.amount>0){charge=bill.amount*per;if(U.balance<charge)notice+=" (SHORT "+ubisFormatBalance(charge-U.balance)+")";U.balance-=charge;ubisLedger(U,"bill",bill.name+(per>1?" x"+per:""),-charge);notice+=":  -"+ubisFormatBalance(charge);}if(bill.items&&bill.items.length>0){var iN=[];for(j=0;j<bill.items.length;j++){item=bill.items[j];var tq=(item.qty||1)*per;key=ubisFindInvKey(U,item.name);if(key&&U.inventory[key]>=tq){U.inventory[key]-=tq;if(U.inventory[key]<=0)delete U.inventory[key];ubisLedger(U,"bill_item",key+" x"+tq,0);iN.push(item.name+" x"+tq);}else iN.push(item.name+" x"+tq+" (MISSING)");}notice+="  Items: "+iN.join(", ");}notices.push(notice);}for(i=0;i<U.settings.income.length;i++){src=U.settings.income[i];if(!src.enabled)continue;ld=U.incomeCounters[src.name]||0;per=Math.floor((cd-ld)/(src.intervalDays||1));if(per<=0)continue;pay=src.amount*per;U.balance+=pay;U.incomeCounters[src.name]=ld+(per*src.intervalDays);ubisLedger(U,"income",src.name+(per>1?" x"+per:""),pay);notices.push("[INCOME] "+src.name+(per>1?" x"+per:"")+":  +"+ubisFormatBalance(pay));}return notices;}

